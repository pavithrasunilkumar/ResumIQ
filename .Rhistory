# ---------------- SAMPLE DATA ----------------
# Sample resumes
resumes <- c(
"python ml sql communication",
"html css javascript react",
"python statistics data analysis excel",
"java spring boot microservices"
)
# Job description
job_desc <- "looking for python developer with ml and sql skills"
# ---------------- FUNCTION ----------------
cosine_similarity <- function(resume, job) {
# Step 1: Convert to lowercase
resume <- tolower(resume)
job <- tolower(job)
# Step 2: Split into words
resume_words <- unlist(strsplit(resume, " "))
job_words <- unlist(strsplit(job, " "))
# Step 3: Create vocabulary
vocab <- unique(c(resume_words, job_words))
# Step 4: Create vectors manually
resume_vec <- numeric(length(vocab))
job_vec <- numeric(length(vocab))
for (i in 1:length(vocab)) {
word <- vocab[i]
# Count in resume
count_r <- 0
for (w in resume_words) {
if (w == word) {
count_r <- count_r + 1
}
}
# Count in job
count_j <- 0
for (w in job_words) {
if (w == word) {
count_j <- count_j + 1
}
}
resume_vec[i] <- count_r
job_vec[i] <- count_j
}
# Step 5: Dot product
dot_product <- 0
for (i in 1:length(vocab)) {
dot_product <- dot_product + (resume_vec[i] * job_vec[i])
}
# Step 6: Magnitude
mag_r <- 0
mag_j <- 0
for (i in 1:length(vocab)) {
mag_r <- mag_r + (resume_vec[i]^2)
mag_j <- mag_j + (job_vec[i]^2)
}
mag_r <- sqrt(mag_r)
mag_j <- sqrt(mag_j)
# Step 7: Cosine similarity
if (mag_r == 0 || mag_j == 0) {
return(0)
} else {
return(dot_product / (mag_r * mag_j))
}
}
# ---------------- APPLY TO ALL RESUMES ----------------
results <- data.frame(Resume = resumes, Score = numeric(length(resumes)))
for (i in 1:length(resumes)) {
score <- cosine_similarity(resumes[i], job_desc)
results$Score[i] <- score
}
# ---------------- RANK RESULTS ----------------
# Manual sorting (descending)
for (i in 1:(nrow(results)-1)) {
for (j in (i+1):nrow(results)) {
if (results$Score[j] > results$Score[i]) {
temp <- results[i, ]
results[i, ] <- results[j, ]
results[j, ] <- temp
}
}
}
# ---------------- DISPLAY ----------------
print("Resume Ranking Based on Match Score:")
print(results)
# Decision for top resume
top_score <- results$Score[1]
if (top_score >= 0.6) {
print("Top Candidate: Selected")
} else {
print("Top Candidate: Not Selected")
}
shiny::runApp('C:/Users/HP/Desktop/RESUMIQ')
